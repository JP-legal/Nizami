{
    "family": "nizami-migrate",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512",
    "memory": "1024",
    "taskRoleArn": "arn:aws:iam::189523310609:role/nizami-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::189523310609:role/service-role/ecsTaskExecutionRole",
    "containerDefinitions": [{
      "name": "web",
      "image": "189523310609.dkr.ecr.eu-west-1.amazonaws.com/nizami/backend:latest",
      "command": ["python", "manage.py", "migrate", "--noinput"],
      "environment": [
        { "name": "DEBUG", "value": "False" },
        { "name": "DB_HOST", "value": "pgbouncer.nizami.local" },
        { "name": "DB_PORT", "value": "5432" },
        { "name": "DB_NAME", "value": "nizami_db" },
        { "name": "DB_USER", "value": "nizami_user" }
      ],
      "secrets": [
        { "name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:eu-west-1:189523310609:secret:nizami/prod/SECRET_KEY-DwTz5S" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:eu-west-1:189523310609:secret:nizami/prod/DB_PASSWORD-esr0g9" },
        { "name": "REDIS_URL", "valueFrom": "arn:aws:secretsmanager:eu-west-1:189523310609:secret:nizami/prod/REDIS_URL-LBJxkG" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:eu-west-1:189523310609:secret:nizami/prod/OPENAI_API_KEY-5uiJO8" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nizami/web",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "migrate"
        }
      }
    }]
  }